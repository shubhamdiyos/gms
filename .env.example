# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gms
DB_USERNAME=gms_user
DB_PASSWORD=your_database_password

# Mail (SMTP) Configuration
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM=your_email@gmail.com

# JPA Configuration
JPA_DDL_AUTO=validate
JPA_SHOW_SQL=false

# Flyway Configuration
FLYWAY_ENABLED=true

# Logging Configuration
LOG_LEVEL_COM_GMS=DEBUG
LOG_LEVEL_BOOTSTRAP=DEBUG

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
