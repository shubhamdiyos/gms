			"item": [
				{
					"name": "📚 Subjects",
					"item": [
						{
							"name": "List Subjects",
							"request": {
								"method": "GET",
								"header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}],
								"url": "{{base_url}}/api/v1/subjects"
							}
						},
						{
							"name": "Create Subject",
							"event": [
								{
									"listen": "test",
									"script": {
										"exec": [
											"if (pm.response.code === 201) {",
											"    const resp = pm.response.json();",
											"    if (resp.id) pm.environment.set('subject_id', resp.id);",
											"}"
										]
									}
								}
							],
							"request": {
								"method": "POST",
								"header": [
									{"key": "Authorization", "value": "Bearer {{jwt_token}}"},
									{"key": "Content-Type", "value": "application/json"}
								],
								"body": {
									"mode": "raw",
									"raw": "{\n    \"subjectName\": \"Mathematics\",\n    \"subjectCode\": \"MATH101\",\n    \"credits\": 4,\n    \"isActive\": true\n}"
								},
								"url": "{{base_url}}/api/v1/subjects"
							}
